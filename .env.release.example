# Template for .env.release local settings. Do not commit .env.release.

# Chrome Web Store item identity.
CWS_PUBLISHER_ID=
CWS_EXTENSION_ID=

# Optional: set this when uploading a specific artifact. Otherwise the CLI uses
# the latest release/*.zip that matches package.json version.
CWS_ZIP=

# Short-lived OAuth access token. Generate it locally with gcloud, for example:
# export CWS_ACCESS_TOKEN="$(gcloud auth print-access-token --impersonate-service-account="$CWS_SERVICE_ACCOUNT" --scopes=https://www.googleapis.com/auth/chromewebstore)"
CWS_ACCESS_TOKEN=

# Service account email used to mint the access token. The account must be added
# in the Chrome Web Store Developer Dashboard and the Chrome Web Store API must
# be enabled in the Google Cloud project.
CWS_SERVICE_ACCOUNT=
GOOGLE_CLOUD_PROJECT=

# Optional CRX settings for local/internal CRX output. ZIP is the Chrome Web
# Store upload artifact.
CHROME_PATH=
CRX_KEY_PATH=private/lightstreamer-event-workbench.pem
